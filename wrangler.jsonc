{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "sinuca-club",
  "compatibility_date": "2026-03-30",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "main": "vinext/server/app-router-entry",
  "assets": {
    "not_found_handling": "none"
  },
  "observability": {
    "enabled": false,
    "head_sampling_rate": 1,
    "logs": {
      "enabled": true,
      "head_sampling_rate": 1,
      "persist": true,
      "invocation_logs": true
    },
    "traces": {
      "enabled": false,
      "persist": true,
      "head_sampling_rate": 1
    }
  }
}
