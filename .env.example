# Copy to .dev.vars for local development with vinext (Cloudflare Workers runtime).
# For plain Node.js tooling (prisma CLI, seed), copy to .env.local instead.

# -------------------------------------------------------------------
# Required
# -------------------------------------------------------------------

# Neon Postgres connection string.
# Leave empty to disable auth and persistence (routes return 503).
DATABASE_URL=

# Secret used by better-auth to sign session cookies.
# Required whenever DATABASE_URL is set. Use any long random string.
BETTER_AUTH_SECRET=local-dev-secret

# -------------------------------------------------------------------
# Optional
# -------------------------------------------------------------------

# Public URL of the app — used by better-auth for cookie domain.
# Defaults to http://localhost:3000 in development.
BETTER_AUTH_URL=http://localhost:3000

# Timeout (ms) for auth session and profile lookups.
# Defaults to 8000. Increase if you see session timeouts in slow envs.
# AUTH_OPERATION_TIMEOUT_MS=8000

# Controls the environment label shown in the dashboard UI.
# Values: "development" | "preview" | "production"
# NEXT_PUBLIC_APP_ENV=development
