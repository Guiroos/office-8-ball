# Use these values for Vercel Preview / sandbox environments

# Neon Postgres connection string for the preview database.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB_NAME?sslmode=require

# Secret used by better-auth to sign session cookies.
# Use a long random secret generated for this environment.
BETTER_AUTH_SECRET=<strong-random-secret>

# Public auth base URL used by better-auth for this deployed environment.
BETTER_AUTH_URL=https://preview.example.com

# Environment label shown in the UI.
NEXT_PUBLIC_APP_ENV=preview
