# Use these values for Vercel Production

# Neon Postgres connection string for the production database.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB_NAME?sslmode=require

# Secret used by Auth.js to sign session cookies.
# Use a long random secret generated for this environment.
NEXTAUTH_SECRET=<strong-random-secret>

# Environment label shown in the UI.
NEXT_PUBLIC_APP_ENV=production
