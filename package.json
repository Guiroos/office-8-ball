{
  "name": "office-8-ball",
  "version": "2.0.3",
  "private": true,
  "scripts": {
    "dev": "vinext dev",
    "dev:e2e": "vinext dev --hostname 127.0.0.1 --port 3000",
    "build": "vinext build",
    "build:vercel": "NITRO_PRESET=vercel vite build",
    "start": "vinext start",
    "deploy:cloudflare": "wrangler deploy",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:headed": "playwright test --headed",
    "e2e:install": "playwright install chromium",
    "postinstall": "prisma generate && node scripts/generate-node-prisma-client.mjs",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:seed": "prisma db seed",
    "prisma:reset": "prisma migrate reset",
    "prisma:status": "prisma migrate status",
    "prisma:studio": "prisma studio",
    "prisma:setup": "prisma migrate dev && prisma db seed"
  },
  "dependencies": {
